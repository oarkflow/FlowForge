# ==============================================================================
# FlowForge — Environment Configuration
# Copy to .env and update values for your deployment.
# ==============================================================================

# --- Server ---
BACKEND_PORT=8082
FRONTEND_PORT=3000
LOG_LEVEL=info

# --- Database ---
DATABASE_PATH=/data/flowforge.db

# --- Authentication ---
# REQUIRED: Set a strong random secret (min 32 chars)
JWT_SECRET=jXeU9RIV5Cm+cbIYddNKBbnV4Rv8KvHt5R0oSQjA10o=

# REQUIRED: 64-character hex string (32 bytes) for AES-256-GCM encryption
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=2ab40cac88c0ac9017322db4254265c2bbea09024caad7c9c15635fd8df75653

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000

# --- Frontend ---
VITE_API_URL=

# --- Artifact Storage ---
# Options: local, s3
ARTIFACT_STORAGE_BACKEND=local
ARTIFACT_STORAGE_PATH=/data/artifacts

# --- S3 / MinIO (if ARTIFACT_STORAGE_BACKEND=s3) ---
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=flowforge-artifacts
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false

# --- Agent ---
AGENT_TOKEN=

# --- GitHub Integration ---
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

# --- GitLab Integration ---
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_WEBHOOK_SECRET=

# --- Bitbucket Integration ---
BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=
BITBUCKET_WEBHOOK_SECRET=

# --- Notifications ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@flowforge.local

SLACK_WEBHOOK_URL=

# --- External Secret Providers ---
VAULT_ADDR=
VAULT_TOKEN=

AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
