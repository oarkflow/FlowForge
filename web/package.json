{
  "name": "flowforge-frontend",
  "private": true,
  "version": "1.0.0",
  "description": "FlowForge CI/CD Platform — SolidJS Frontend",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.15.4",
    "chart.js": "^4.4.0",
    "date-fns": "^3.6.0",
    "js-yaml": "^4.1.0",
    "jszip": "^3.10.1",
    "monaco-editor": "^0.47.0",
    "solid-icons": "^1.1.0",
    "solid-js": "^1.9.11",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@solidjs/testing-library": "^0.8.10",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.12.0",
    "jsdom": "^25.0.1",
    "msw": "^2.7.3",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "vite": "^6.4.1",
    "vite-plugin-solid": "^2.11.11",
    "vitest": "^3.1.1"
  },
  "main": "index.js",
  "keywords": [],
