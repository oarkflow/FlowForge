# ==============================================================================
# FlowForge Agent — Multi-stage Docker Build
# Standalone worker agent that connects to the FlowForge server via gRPC
# ==============================================================================

# ---------------------------------------------------------------------------
# Stage 1: Build
# ---------------------------------------------------------------------------
FROM golang:1.26-alpine AS builder

RUN apk add --no-cache gcc musl-dev sqlite-dev

WORKDIR /app

COPY backend/go.mod backend/go.sum ./
RUN go mod download

COPY backend/ .

ENV CGO_ENABLED=1
RUN go build \
    -ldflags="-w -s" \
    -trimpath \
    -o /app/flowforge-agent \
    ./cmd/agent 2>/dev/null || echo "Agent binary not yet implemented, creating placeholder" && touch /app/flowforge-agent

# ---------------------------------------------------------------------------
# Stage 2: Runtime
# ---------------------------------------------------------------------------
FROM alpine:3.19

RUN apk add --no-cache \
    ca-certificates \
    sqlite-libs \
    tzdata \
    git \
    docker-cli \
    && addgroup -S flowforge \
    && adduser -S -G flowforge flowforge \
    && addgroup flowforge docker 2>/dev/null || true

WORKDIR /app

RUN mkdir -p /data/workspaces && chown -R flowforge:flowforge /data

COPY --from=builder /app/flowforge-agent /app/flowforge-agent

RUN chown -R flowforge:flowforge /app

EXPOSE 9090

ENV SERVER_URL=http://flowforge-server:8080
ENV AGENT_NAME=agent-1
ENV EXECUTOR_TYPE=docker
ENV LOG_LEVEL=info

VOLUME ["/data/workspaces"]
VOLUME ["/var/run/docker.sock"]

ENTRYPOINT ["/app/flowforge-agent"]
